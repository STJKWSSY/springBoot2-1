<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jiangnan.www.springboot03admin.demos.web.mapper.SysAccountMapper">

    <insert id="insert">
        INSERT INTO sys_acccount_demo (name, age)
        VALUES (#{name}, #{age})
    </insert>

    <update id="update">
        UPDATE sys_acccount_demo
        SET name = #{name},
            age  = #{age}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE
        FROM sys_acccount_demo
        WHERE id = #{id}
    </delete>

    <select id="findById" resultType="com.jiangnan.www.springboot03admin.demos.web.pojo.SysAccount">
        SELECT *
        FROM sys_acccount_demo
        WHERE id = #{id}
    </select>

    <select id="findAll" resultType="com.jiangnan.www.springboot03admin.demos.web.pojo.SysAccount">
        SELECT *
        FROM sys_acccount_demo
    </select>

</mapper>